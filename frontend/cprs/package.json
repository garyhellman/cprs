{
  "name": "cprs",
  "product": "ext",
  "version": "0.0.1",
  "description": "cprs description for Ext JS app CPRS",
  "repository": {
    "type": "git",
    "url": "https://github.com/"
  },
  "keywords": [
    "Ext",
    "JS",
    "Sencha",
    "HTML5"
  ],
  "author": "Sencha, Inc.",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/"
  },
  "homepage": "http://www.sencha.com",
  "scripts": {
    "start": "npm run dev",
    "clean": "rimraf build",
    "dev": "webpack-dev-server --env profile=desktop --env browser=yes --env verbose=no",
    "build": "npm run clean && cross-env webpack --env profile=desktop --env environment=production --env treeshake=yes",
    "build:spring": "cross-env JAVA_HOME=/usr/lib/jvm/java-8-openjdk-amd64 webpack --env profile=desktop --env environment=development --env browser=no --env watch=no",
    "build:testing": "npm run clean && cross-env webpack --env profile=desktop --env treeshake=yes --env cmdopts=--testing",
    "postinstall": "npm prune"
  },
  "dependencies": {
    "@sencha/ext": "~8.0.0",
    "@sencha/ext-classic": "~8.0.0",
    "@sencha/ext-classic-theme-triton": "~8.0.0",
    "@sencha/ext-ux": "^8.0.0"
  },
  "devDependencies": {
    "@babel/cli": "^7.5.5",
    "@babel/core": "^7.5.5",
    "@babel/plugin-proposal-object-rest-spread": "^7.5.5",
    "@babel/plugin-transform-async-to-generator": "^7.5.0",
    "@babel/plugin-transform-regenerator": "^7.4.5",
    "@babel/preset-env": "^7.5.5",
    "@sencha/ext-webpack-plugin": "~8.0.0",
    "babel-loader": "^8.0.6",
    "babel-plugin-add-module-exports": "^1.0.2",
    "cross-env": "^5.2.0",
    "lodash.find": "^4.6.0",
    "portfinder": "^1.0.21",
    "replace": "^1.1.1",
    "rimraf": "^3.0.2",
    "webpack": "^5.55.1",
    "webpack-cli": "^4.8.0",
    "webpack-dev-server": "^4.2.1"
  }
}
